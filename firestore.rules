rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: Disable all read/write by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }
    
    // Entity Validation Helpers
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 128
        && data.fullName is string && data.fullName.size() <= 128;
    }
    
    function isValidOrder(data) {
      return data.trackingId is string && data.trackingId.size() <= 128
        && data.customerName is string && data.customerName.size() <= 128;
    }

    // Match Blocks for each collection
    match /users/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isSignedIn() && isOwner(userId);
    }
    
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOrder(request.resource.data);
      allow update: if isSignedIn() && isValidOrder(request.resource.data);
      allow delete: if false;
    }
  }
}
